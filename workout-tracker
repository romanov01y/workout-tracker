<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Трекер тренировок</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-page:    #EDEBE6;
    --bg-card:    #F5F4F0;
    --bg-input:   #FFFFFF;
    --bg-bot-msg: #E8E6E0;
    --bg-user-msg:#D0CEC7;
    --text-main:  #2C2C2A;
    --text-muted: #5F5E5A;
    --text-hint:  #888780;
    --border:     rgba(44,44,42,0.12);
    --border-md:  rgba(44,44,42,0.20);
    --accent:     #3C3489;
    --accent-light:#EEEDFE;
    --radius-sm:  8px;
    --radius-md:  12px;
    --radius-lg:  16px;
    --font: -apple-system, 'Segoe UI', sans-serif;
  }

  body {
    background: var(--bg-page);
    font-family: var(--font);
    color: var(--text-main);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-bottom: 80px;
  }

  /* ── MAIN CONTENT ── */
  #app-screen {
    flex: 1;
    padding: 20px 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Welcome block */
  .welcome-block {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    padding: 28px 20px 24px;
    text-align: center;
  }
  .welcome-block h1 {
    font-size: 20px;
    font-weight: 500;
    color: var(--text-main);
    margin-bottom: 8px;
  }
  .welcome-block p {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 18px;
    line-height: 1.5;
  }
  .bounce-arrow {
    font-size: 26px;
    animation: bounce 1.4s ease-in-out infinite;
    display: block;
    color: var(--accent);
  }
  @keyframes bounce {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(8px); }
  }

  /* Section panels */
  .panel {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    overflow: hidden;
  }
  .panel-header {
    padding: 16px 18px 12px;
    font-size: 15px;
    font-weight: 500;
    color: var(--text-main);
    border-bottom: 0.5px solid var(--border);
  }
  .panel-body { padding: 16px 18px; }

  /* Program type buttons */
  .prog-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .prog-btn {
    background: var(--bg-input);
    border: 0.5px solid var(--border-md);
    border-radius: var(--radius-md);
    padding: 14px 10px;
    text-align: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-main);
  }
  .prog-btn:hover, .prog-btn.active {
    background: var(--accent-light);
    border-color: var(--accent);
    color: var(--accent);
  }
  .prog-btn span { display: block; font-size: 11px; font-weight: 400; color: var(--text-hint); margin-top: 3px; }

  /* Workout program days grid */
  .days-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 14px;
  }
  .day-col {
    background: var(--bg-input);
    border-radius: var(--radius-md);
    border: 0.5px solid var(--border);
    padding: 12px;
  }
  .day-col h3 {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 0.5px solid var(--border);
  }
  .day-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .day-col li {
    font-size: 12px;
    color: var(--text-main);
    line-height: 1.4;
    padding-left: 10px;
    position: relative;
  }
  .day-col li::before {
    content: '';
    position: absolute;
    left: 0; top: 6px;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--text-hint);
  }
  .day-col .ex-sets {
    display: block;
    font-size: 11px;
    color: var(--text-hint);
  }

  /* Coming soon */
  .coming-soon {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    padding: 40px 20px;
    text-align: center;
  }
  .coming-soon p { font-size: 14px; color: var(--text-muted); }

  /* ── TRACKER CHAT ── */
  .chat-wrap {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 160px);
  }
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 12px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .msg {
    max-width: 82%;
    padding: 10px 13px;
    border-radius: var(--radius-md);
    font-size: 14px;
    line-height: 1.5;
    white-space: pre-wrap;
  }
  .msg-bot {
    background: var(--bg-bot-msg);
    color: var(--text-main);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .msg-user {
    background: var(--accent);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .chat-input-row {
    display: flex;
    gap: 8px;
    padding-top: 10px;
    border-top: 0.5px solid var(--border);
  }
  .chat-input-row input {
    flex: 1;
    background: var(--bg-input);
    border: 0.5px solid var(--border-md);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    font-size: 14px;
    color: var(--text-main);
    outline: none;
  }
  .chat-input-row input:focus { border-color: var(--accent); }
  .send-btn {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    padding: 0 16px;
    font-size: 14px;
    cursor: pointer;
    white-space: nowrap;
  }
  .send-btn:active { opacity: 0.85; }

  /* ── RESULTS ── */
  .results-wrap { display: flex; flex-direction: column; gap: 16px; }
  .result-day-header {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .result-entry {
    background: var(--bg-input);
    border-radius: var(--radius-md);
    border: 0.5px solid var(--border);
    padding: 12px 14px;
    margin-bottom: 8px;
  }
  .result-entry .ex-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-main);
    margin-bottom: 4px;
  }
  .result-entry .ex-detail {
    font-size: 13px;
    color: var(--text-muted);
  }
  .results-days-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .results-empty {
    text-align: center;
    color: var(--text-hint);
    font-size: 14px;
    padding: 30px 0;
  }

  /* ── BOTTOM NAV ── */
  nav {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--bg-card);
    border-top: 0.5px solid var(--border-md);
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    z-index: 100;
  }
  nav button {
    background: none;
    border: none;
    padding: 10px 4px 12px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    font-size: 10px;
    color: var(--text-hint);
    transition: color 0.15s;
    line-height: 1.3;
    text-align: center;
  }
  nav button svg {
    width: 22px; height: 22px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }
  nav button.active { color: var(--accent); }

  /* scrollbar */
  .chat-messages::-webkit-scrollbar { width: 3px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--border-md); border-radius: 4px; }
</style>
</head>
<body>

<div id="app-screen"></div>

<nav>
  <button id="nav-program" onclick="showTab('program')">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
    Программа
  </button>
  <button id="nav-tracker" onclick="showTab('tracker')">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 15"/></svg>
    Трекер
  </button>
  <button id="nav-results" onclick="showTab('results')">
    <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
    Мои результаты
  </button>
</nav>

<script>
// ── DATA ──
const PROGRAM_FULLBODY = {
  day1: [
    { name: 'Приседания со штангой', sets: '2×10' },
    { name: 'Жим штанги лёжа',       sets: '2×10' },
    { name: 'Румынская тяга',         sets: '2×10' },
    { name: 'Тяга вертикального блока', sets: '3×12' },
    { name: 'Жим гантелей на плечи сидя', sets: '2×10' },
    { name: 'Разгибание ног в тренажёре', sets: '2×12' },
    { name: 'Сведения рук (бабочка)', sets: '2×12' },
    { name: 'Сгибание рук с гантелями (бицепс)', sets: '2×10' },
    { name: 'Французский жим',        sets: '2×10' },
    { name: 'Пресс',                  sets: '—' },
  ],
  day2: [
    { name: 'Болгарские приседания',  sets: '2×10' },
    { name: 'Жим ногами / Гакк',      sets: '2×10' },
    { name: 'Жим гантелей на наклонной', sets: '3×10' },
    { name: 'Тяга штанги/гантелей в наклоне', sets: '2×10' },
    { name: 'Тяга горизонтального блока', sets: '3×10' },
    { name: 'Разводка гантелей (средняя дельта)', sets: '2×10' },
    { name: 'Разведения на заднюю дельту', sets: '2×10' },
    { name: 'Обратные сгибания на бицепс', sets: '—' },
    { name: 'Разгибания на трицепс',  sets: '—' },
    { name: 'Подъёмы на икры',        sets: '—' },
    { name: 'Пресс',                  sets: '—' },
  ]
};

// ── STATE ──
let currentTab = 'home';
let selectedProgram = null;
let chatState = 'ask_exercise'; // ask_exercise | ask_weight_sets
let currentExercise = '';
let chatLog = [];

function getTodayStr() {
  const d = new Date();
  return d.toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

// ── STORAGE ──
function saveEntry(exercise, weight, sets, reps) {
  const key = 'workout_log';
  const existing = JSON.parse(localStorage.getItem(key) || '[]');
  existing.push({ date: getTodayStr(), exercise, weight, sets, reps, ts: Date.now() });
  localStorage.setItem(key, JSON.stringify(existing));
}

function getLog() {
  return JSON.parse(localStorage.getItem('workout_log') || '[]');
}

function getLastTwoDays() {
  const log = getLog();
  if (!log.length) return [];
  const dates = [...new Set(log.map(e => e.date))].sort((a,b) => {
    const pa = a.split('.').reverse().join('-');
    const pb = b.split('.').reverse().join('-');
    return pb.localeCompare(pa);
  });
  return dates.slice(0, 2);
}

// ── RENDER ──
const screen = document.getElementById('app-screen');

function showTab(tab) {
  currentTab = tab;
  ['program','tracker','results'].forEach(t => {
    document.getElementById('nav-'+t).classList.toggle('active', t === tab);
  });
  render();
}

function render() {
  if (currentTab === 'home') {
    renderHome();
  } else if (currentTab === 'program') {
    renderProgram();
  } else if (currentTab === 'tracker') {
    renderTracker();
  } else if (currentTab === 'results') {
    renderResults();
  }
}

function renderHome() {
  screen.innerHTML = `
    <div class="welcome-block">
      <h1>Добро пожаловать!</h1>
      <p>Выберите раздел ниже, чтобы начать</p>
      <span class="bounce-arrow">↓</span>
    </div>
  `;
}

function renderProgram() {
  let inner = `
    <div class="panel">
      <div class="panel-header">Выберите программу</div>
      <div class="panel-body">
        <div class="prog-buttons">
          <div class="prog-btn ${selectedProgram==='fullbody'?'active':''}" onclick="selectProgram('fullbody')">
            Фулл-боди<span>2 дня в неделю</span>
          </div>
          <div class="prog-btn ${selectedProgram==='split'?'active':''}" onclick="selectProgram('split')">
            Сплит 3-дневный<span>грудь / спина / ноги</span>
          </div>
        </div>
      </div>
    </div>
  `;

  if (selectedProgram === 'fullbody') {
    const makeList = (arr) => arr.map(e =>
      `<li>${e.name}<span class="ex-sets">${e.sets}</span></li>`
    ).join('');
    inner += `
      <div class="panel">
        <div class="panel-header">Фулл-боди — программа</div>
        <div class="panel-body" style="padding-top:8px">
          <div class="days-grid">
            <div class="day-col">
              <h3>День 1</h3>
              <ul>${makeList(PROGRAM_FULLBODY.day1)}</ul>
            </div>
            <div class="day-col">
              <h3>День 2</h3>
              <ul>${makeList(PROGRAM_FULLBODY.day2)}</ul>
            </div>
          </div>
        </div>
      </div>
    `;
  }

  if (selectedProgram === 'split') {
    inner += `
      <div class="coming-soon">
        <p>Здесь пока ничего нет.<br>Возможно, добавлю позже.</p>
      </div>
    `;
  }

  screen.innerHTML = inner;
}

function selectProgram(p) {
  selectedProgram = p;
  renderProgram();
}

// ── TRACKER ──
function renderTracker() {
  const msgs = chatLog.map(m => `
    <div class="msg msg-${m.from}">${escHtml(m.text)}</div>
  `).join('');

  screen.innerHTML = `
    <div class="panel" style="flex:1; display:flex; flex-direction:column;">
      <div class="panel-header">Трекер тренировки — ${getTodayStr()}</div>
      <div class="panel-body" style="flex:1; display:flex; flex-direction:column; padding:12px 14px;">
        <div class="chat-messages" id="chat-messages">${msgs}</div>
        <div class="chat-input-row">
          <input id="chat-input" type="text" placeholder="Введите сообщение…" onkeydown="if(event.key==='Enter') sendChat()">
          <button class="send-btn" onclick="sendChat()">Отправить</button>
        </div>
      </div>
    </div>
  `;

  scrollChat();

  if (chatLog.length === 0) {
    addBotMessage('Привет! Введите название упражнения, которое вы выполняете сегодня.');
  }
}

function scrollChat() {
  const el = document.getElementById('chat-messages');
  if (el) el.scrollTop = el.scrollHeight;
}

function addBotMessage(text) {
  chatLog.push({ from: 'bot', text });
  const el = document.getElementById('chat-messages');
  if (el) {
    const div = document.createElement('div');
    div.className = 'msg msg-bot';
    div.textContent = text;
    el.appendChild(div);
    scrollChat();
  }
}

function sendChat() {
  const input = document.getElementById('chat-input');
  const val = input.value.trim();
  if (!val) return;
  input.value = '';

  chatLog.push({ from: 'user', text: val });
  const el = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = 'msg msg-user';
  div.textContent = val;
  el.appendChild(div);
  scrollChat();

  setTimeout(() => handleBotLogic(val), 300);
}

let pendingWeight = '';

function handleBotLogic(userInput) {
  if (chatState === 'ask_exercise') {
    currentExercise = userInput;
    chatState = 'ask_weight';
    addBotMessage(`Упражнение: ${currentExercise}\nВведите рабочий вес (кг):`);

  } else if (chatState === 'ask_weight') {
    pendingWeight = userInput;
    chatState = 'ask_sets';
    addBotMessage('Введите количество подходов и повторений\n(например: 3×10):');

  } else if (chatState === 'ask_sets') {
    const setsInput = userInput;
    let sets = '?', reps = '?';
    const match = setsInput.match(/(\d+)[×xXхХ](\d+)/);
    if (match) { sets = match[1]; reps = match[2]; }

    saveEntry(currentExercise, pendingWeight, sets, reps);

    const summary = `${getTodayStr()}:\n${currentExercise}: ${pendingWeight}кг × ${reps} × ${sets}`;
    addBotMessage(`✓ Записано!\n${summary}\n\nВведите следующее упражнение или напишите «готово» для завершения.`);

    chatState = 'ask_exercise';
    currentExercise = '';
    pendingWeight = '';

  }
}

// ── RESULTS ──
function renderResults() {
  const days = getLastTwoDays();
  const log = getLog();

  if (!days.length) {
    screen.innerHTML = `
      <div class="coming-soon">
        <p>Записей пока нет.<br>Начните тренировку в разделе «Трекер».</p>
      </div>
    `;
    return;
  }

  const cols = days.map(date => {
    const entries = log.filter(e => e.date === date);
    const rows = entries.map(e => `
      <div class="result-entry">
        <div class="ex-name">${escHtml(e.exercise)}</div>
        <div class="ex-detail">${escHtml(e.weight)} кг × ${escHtml(e.reps)} × ${escHtml(e.sets)} подх.</div>
      </div>
    `).join('');
    return `
      <div>
        <div class="result-day-header">${date}</div>
        ${rows}
      </div>
    `;
  }).join('');

  screen.innerHTML = `
    <div class="panel">
      <div class="panel-header">Последние две тренировки</div>
      <div class="panel-body">
        <div class="results-days-grid">${cols}</div>
      </div>
    </div>
  `;
}

function escHtml(s) {
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}

// ── INIT ──
renderHome();
document.getElementById('nav-program').addEventListener('click', () => {});
document.getElementById('nav-tracker').addEventListener('click', () => {});
document.getElementById('nav-results').addEventListener('click', () => {});

// Show home on load, no nav item active
showTab('home');
// Then deactivate all nav
['program','tracker','results'].forEach(t =>
  document.getElementById('nav-'+t).classList.remove('active')
);

// Telegram Mini App init
if (window.Telegram && window.Telegram.WebApp) {
  window.Telegram.WebApp.ready();
  window.Telegram.WebApp.expand();
}
</script>
</body>
</html>
